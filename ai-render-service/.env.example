# Copy to .env or .env.local. Used when running from ai-render-service or when root delegates jobs API.
# Do not add VERCEL_OIDC_TOKEN here (expires; causes 401). Use OPENAI_API_KEY and/or AI_GATEWAY_API_KEY.

OPENAI_API_KEY=
PORT=3000

# PropertyData valuation (server-side only). Leave empty to disable indicative valuation.
PROPERTYDATA_API_KEY=

# Redis for valuation cache (24h TTL). Upstash REST URL/token for serverless.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
